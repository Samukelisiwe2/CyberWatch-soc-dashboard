@model CyberWatch_web.Models.DashboardViewModel

@{
    ViewData["Title"] = "CyberWatch Dashboard";
}

<div class="container mt-4">
    <div class="mb-4">
        <h1>CyberWatch SOC Dashboard</h1>
        <p class="text-muted">
            Security monitoring and incident overview
        </p>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Total Alerts</h6>
                    <h2>@Model.TotalAlerts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-warning">
                <div class="card-body">
                    <h6 class="text-muted">Open Alerts</h6>
                    <h2>@Model.OpenAlerts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <h6 class="text-muted">High Severity</h6>
                    <h2>@Model.HighSeverityAlerts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-primary">
                <div class="card-body">
                    <h6 class="text-muted">Login Events</h6>
                    <h2>@Model.TotalSecurityLogs</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong>Recent Security Alerts</strong>
        </div>

        <div class="card-body p-0">

            @if (Model.RecentAlerts.Count == 0)
            {
                <div class="p-4 text-center text-muted">
                    No security alerts have been detected yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Alert Type</th>
                                <th>Username</th>
                                <th>IP Address</th>
                                <th>Severity</th>
                                <th>Status</th>
                                <th>Created</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var alert in Model.RecentAlerts)
                            {
                                <tr>
                                    <td>@alert.AlertType</td>
                                    <td>@alert.Username</td>
                                    <td>@alert.IpAddress</td>

                                    <td>
                                        @if (alert.Severity ==
                                            CyberWatch_web.Models.AlertSeverity.High)
                                        {
                                            <span class="badge bg-danger">
                                                High
                                            </span>
                                        }
                                        else if (alert.Severity ==
                                            CyberWatch_web.Models.AlertSeverity.Medium)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Medium
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Low
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @alert.Status
                                        </span>
                                    </td>

                                    <td>
                                        @alert.CreatedAtUtc
                                        .ToLocalTime()
                                        .ToString("dd MMM yyyy HH:mm")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>